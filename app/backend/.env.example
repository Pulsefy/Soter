DATABASE_URL="file:./prisma/dev.db"
WEBHOOK_SECRET="change-me-to-a-strong-random-secret"
SOROBAN_NETWORK="testnet"
AID_ESCROW_CONTRACT_ID=""
VERIFICATION_MODE="mock"

# CORS Configuration
# CORS_ALLOWLIST supports wildcard patterns for Vercel preview deployments
# Examples:
# - Exact matches: "https://app.example.com,https://staging.example.com"
# - Vercel previews: "https://*.vercel.app,https://app.example.com"
# - Specific patterns: "https://pr-*.example-app.vercel.app,https://app.example.com"
CORS_ALLOWLIST="http://localhost:3000,http://localhost:3001,http://localhost:5173"

# Production-only origins for sensitive endpoints (admin, financial operations)
# These endpoints are never accessible from preview deployments
CORS_PRODUCTION_ORIGINS="https://app.example.com"

# Legacy CORS configuration (deprecated, use CORS_ALLOWLIST instead)
# CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# Allow credentials in CORS requests (default: false)
CORS_ALLOW_CREDENTIALS="false"

# Rate limiting configuration
API_RATE_LIMIT="100"
THROTTLE_TTL="60000"