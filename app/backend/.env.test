# E2E Test Environment Configuration
# This file contains CI-safe settings for end-to-end testing

# Server Configuration
NODE_ENV=test
PORT=3001

# Database Configuration - Use test PostgreSQL database
DATABASE_URL="postgresql://test:test@localhost:5432/soter_test?schema=public"

# API Configuration - Test API key
API_KEY=test-api-key-for-e2e-testing

# Redis Configuration - Disabled for testing
REDIS_HOST=
REDIS_PORT=

# Blockchain Configuration - Use mock adapter for testing
ONCHAIN_ADAPTER=mock
STELLAR_RPC_URL=http://localhost:8000/soroban/rpc
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
SOROBAN_CONTRACT_ID=test-contract-id

# Logging - Reduce noise in test output
LOG_LEVEL=error

# Rate Limiting - Disabled for testing
RATE_LIMIT_ENABLED=false

# Queue Configuration - Use memory queues for testing
BULLMQ_REDIS_HOST=
BULLMQ_REDIS_PORT=
